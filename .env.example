# tidx environment variables
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# To use it locally with `cargo run`, export the vars (or use direnv/dotenvx):
#   set -a && source .env && set +a && cargo run -- up
#
# For docker-compose, it is picked up automatically (or via `env_file:`).

# --- RPC credentials (basic-auth password, referenced by rpc_password_env) ---
TIDX_RPC_PASSWORD_MODERATO=
TIDX_RPC_PASSWORD_MAINNET=

# --- PostgreSQL password (referenced by pg_password_env, if used) ---
# TIDX_PG_PASSWORD=

# --- ClickHouse password (referenced by [chains.clickhouse].password_env, if used) ---
# CH_PASSWORD=
