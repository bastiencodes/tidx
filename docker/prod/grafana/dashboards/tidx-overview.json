{
  "id": null,
  "uid": "tidx-overview",
  "title": "tidx — Overview",
  "description": "General operational health: sync progress, indexing throughput, sink write path, and RPC performance. Pair with the 'tidx — ERC20 Metadata' dashboard when drilling into the metadata pipeline.",
  "tags": ["tidx", "overview"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "hide": 0,
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        }
      },
      {
        "type": "query",
        "name": "chain_id",
        "label": "Chain",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(tidx_synced_block, chain_id)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Sync Health",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Synced block",
      "description": "Highest block contiguously synced (no gaps below).",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "tidx_synced_block{chain_id=~\"$chain_id\"}",
          "legendFormat": "chain {{chain_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Chain head",
      "description": "Latest block the RPC endpoint reports — our target.",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "tidx_sync_head_block{chain_id=~\"$chain_id\"}",
          "legendFormat": "chain {{chain_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Sync lag (blocks)",
      "description": "head - synced. Healthy is single-digit on a good RPC; persistent double-digit lag is a red flag.",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "tidx_sync_lag_blocks{chain_id=~\"$chain_id\"}",
          "legendFormat": "chain {{chain_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Sync rate (blk/s)",
      "description": "Rolling 5s rate maintained by the sync engine.",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "tidx_sync_blocks_per_second{chain_id=~\"$chain_id\"}",
          "legendFormat": "chain {{chain_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Gaps (blocks)",
      "description": "Blocks missing between backfill_num and synced_num, per sink. Any non-zero value means gap-fill is still working.",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (chain_id) (tidx_gap_blocks{chain_id=~\"$chain_id\"})",
          "legendFormat": "chain {{chain_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Backfill remaining",
      "description": "Postgres backfill distance-to-origin. 0 = historic sync complete.",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "tidx_backfill_remaining_blocks{sink=\"postgres\",chain_id=~\"$chain_id\"}",
          "legendFormat": "chain {{chain_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Synced vs head over time",
      "description": "Divergence between the lines = growing sync lag.",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "tidx_synced_block{chain_id=~\"$chain_id\"}", "legendFormat": "synced (chain {{chain_id}})", "refId": "A" },
        { "expr": "tidx_sync_head_block{chain_id=~\"$chain_id\"}", "legendFormat": "head (chain {{chain_id}})", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 0 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Sync rate over time",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "tidx_sync_blocks_per_second{chain_id=~\"$chain_id\"}",
          "legendFormat": "chain {{chain_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 20 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Indexing Throughput",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Blocks / txs / logs indexed (per minute)",
      "description": "5m rate scaled to per-minute. Spikes are normal during backfill.",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (chain_id) (rate(tidx_blocks_indexed_total{chain_id=~\"$chain_id\"}[5m])) * 60", "legendFormat": "blocks (chain {{chain_id}})", "refId": "A" },
        { "expr": "sum by (chain_id) (rate(tidx_txs_indexed_total{chain_id=~\"$chain_id\"}[5m])) * 60",    "legendFormat": "txs (chain {{chain_id}})",    "refId": "B" },
        { "expr": "sum by (chain_id) (rate(tidx_logs_indexed_total{chain_id=~\"$chain_id\"}[5m])) * 60",   "legendFormat": "logs (chain {{chain_id}})",   "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Sink write p99 by table",
      "description": "Per-table 99th-percentile write duration, split by sink (postgres/clickhouse).",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, sink, table) (rate(tidx_sink_write_duration_seconds_bucket[5m])))",
          "legendFormat": "{{sink}} / {{table}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 0 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Sink errors (rate)",
      "description": "Non-zero = sink write failures. Alert candidate.",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(tidx_sink_errors_total[5m])",
          "legendFormat": "{{sink}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 20 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Sink rows written (rate)",
      "description": "Rows/sec flowing into each sink+table combination.",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (sink, table) (rate(tidx_sink_write_rows_total[5m]))",
          "legendFormat": "{{sink}} / {{table}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 300,
      "type": "row",
      "title": "RPC",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "RPC request rate by method",
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (method) (rate(tidx_rpc_requests_total[5m]))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 20,
            "stacking": { "mode": "normal", "group": "A" }
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "RPC latency p95 by method",
      "gridPos": { "x": 12, "y": 31, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, method) (rate(tidx_rpc_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 0 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "RPC success rate (5m)",
      "description": "rate(success=true) / rate(total). Red below 99%.",
      "gridPos": { "x": 0, "y": 39, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(tidx_rpc_requests_total{success=\"true\"}[5m])) / clamp_min(sum(rate(tidx_rpc_requests_total[5m])), 1e-9)",
          "legendFormat": "success",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "RPC errors (rate)",
      "description": "Failed RPC requests per second. Bursts usually correlate with provider-side incidents.",
      "gridPos": { "x": 8, "y": 39, "w": 16, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (method) (rate(tidx_rpc_requests_total{success=\"false\"}[5m]))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 20 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    }
  ]
}
